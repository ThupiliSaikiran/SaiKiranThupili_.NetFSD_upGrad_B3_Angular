@model List<Products>;

<h1 class="display-4">Employee Details</h1>
<div>

    <table class="table">
        <thead>
            <tr>
                <th>Product Id</th>
                <th>Product Name</th>
                <th>Product Price</th>
                <th>Category</th>
                <th>View</th>

               

            </tr>

        </thead>

        <tbody>
            @foreach (var prod in Model)
            {
                <tr>
                    <td>@prod.productId</td>
                    <td>@prod.productName</td>
                    <td>@prod.price</td>
                    <td>@prod.category</td>
                    <td> <a asp-controller="Product" asp-action="Details" asp-route-id="@prod.productId">view</a></td>
                </tr>

            }

        </tbody>

    </table>

</div>

