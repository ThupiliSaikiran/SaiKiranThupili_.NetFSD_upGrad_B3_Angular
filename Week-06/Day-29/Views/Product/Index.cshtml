@model List<Product>
<h1>Product Lists</h1>

<a class="btn btn-primary" asp-action="AddProduct">Add Product</a>

<table class="table">
    <thead>
        <tr>
            <th>Product Id</th>
            <th>Product Name</th>
            <th>Price</th>
            <th>Category</th>
        </tr>

    </thead>

    <tbody>
        @foreach( Product product in Model)
        {
            <tr>
                <td>@product.ProductId</td>
                <td>@product.ProductName</td>
                <td>@product.Price</td>
                <td>@product.Category</td>
                <td>
                    <a
                        asp-controller="Product"
                        asp-action="Details"
                        asp-route-id="@product.ProductId"
                        >Details</a>
                    <a asp-controller="Product"
                       asp-action="Edit"
                       asp-route-id="@product.ProductId">Edit</a>
                    <a asp-controller="Product"
                       asp-action="Details"
                       asp-route-id="@product.ProductId">Delete</a>
                </td>
            </tr>
            
        }
        
    </tbody>
    
</table>